version: 1
name: PCForge Website
type: web
plan: free
services:
  - type: web
    name: pcforge
    runtime: static
    repo: https://github.com/JOUW_GITHUB_USERNAME/pcforge   # ← VERANDER DIT!
    branch: main
    rootDir: .
    buildCommand: ""          # Geen build nodig voor statische site
    staticPublishPath: "."    # Alles in de root map publiceren (index.html)
    envVars: []
    autoDeploy: true
